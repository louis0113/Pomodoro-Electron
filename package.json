{
  "name": "pomodoro-electron",
  "version": "1.0.0",
  "description": "Um simples app de Pomodoro funcional feito com Electron",
  "author": {
    "name": "Luiz Henrique",
    "email": "luiz@example.com"
  },
  "homepage": "https://github.com/luizhenrique/pomodoro-electron",
  "license": "MIT",
  "private": true,
  "main": "main/main.js",

  "scripts": {
    "start": "electron .",
    "dev": "electron --inspect=5858 .",

    "build": "electron-builder",

    "build:mac:x64": "electron-builder --mac dmg --x64 --publish never",
    "build:mac:arm64": "electron-builder --mac dmg --arm64 --publish never",
    "build:mac:universal": "electron-builder --mac dmg --universal --publish never",

    "build:mac:all": "npm run build:mac:x64 && npm run build:mac:arm64 && npm run build:mac:universal",

    "build:win": "electron-builder --win",

    "build:linux": "electron-builder --linux",

    "release": "electron-builder --publish always"
  },

  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "electron": "40.8.0",
    "electron-builder": "26.8.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0"
  },

  "build": {
    "appId": "com.pomodoro.app",
    "productName": "Pomodoro-Electron",

    "asar": true,
    "compression": "store",

    "artifactName": "${productName}-${version}-${arch}.${ext}",

    "publish": [
      {
        "provider": "github"
      }
    ],

    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },

    "files": [
      "main/**/*",
      "renderer/**/*",
      "index.html",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "assets/",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],

    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"]
    },

    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },

    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },

    "linux": {
      "icon": "assets",
      "category": "Utility",
      "maintainer": "Luiz Henrique <luiz@example.com>",
      "target": ["AppImage", "deb"]
    }
  }
}
